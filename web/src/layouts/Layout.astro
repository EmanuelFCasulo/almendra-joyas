---
import '../styles/global.css';
import TopBanner from '../components/TopBanner.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFlotante from '../components/WhatsAppFlotante.astro';
import Toast from '../components/Toast.astro';
import GuiaTalles from '../components/GuiaTalles.astro';
import logo from '../assets/img/logo.jpg';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Título y descripción para SEO -->
		<title>Almendra Joyas | Bijouterie Artesanal</title>
		<meta name="description" content="Descubrí nuestra colección de anillos, pulseras y collares. Elegí tus favoritos y armá tu pedido online." />
		
		<!-- Open Graph - Para WhatsApp, Instagram, Facebook, etc -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content="Almendra Joyas | Bijouterie Artesanal" />
		<meta property="og:description" content="Descubrí nuestra colección de anillos, pulseras y collares. Elegí tus favoritos y armá tu pedido online." />
		<meta property="og:image" content={logo.src} />
		<meta property="og:url" content="https://almendrajoyas.com" />
		
		<!-- Twitter Card -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:title" content="Almendra Joyas | Bijouterie Artesanal" />
		<meta property="twitter:description" content="Descubrí nuestra colección de anillos, pulseras y collares. Elegí tus favoritos y armá tu pedido online." />
		<meta property="twitter:image" content={logo.src} />
		
		<!-- Otros metadatos útiles -->
		<meta name="theme-color" content="#92400e" />
		<meta name="application-name" content="Almendra Joyas" />
	</head>
	<body class="bg-stone-50 min-h-screen flex flex-col">
		<TopBanner />
		<Header />
		<!-- pt-28 compensa la altura del banner (7) + header fijo (h-16) -->
		<div class="pt-28 flex-1">
			<slot />
		</div>
		<Footer />
		<WhatsAppFlotante />
		<Toast />
		<GuiaTalles />
	</body>
</html>
