---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFlotante from '../components/WhatsAppFlotante.astro';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Almendra Joyas</title>
	</head>
	<body class="bg-stone-50 min-h-screen flex flex-col">
		<Header />
		<!-- pt-16 compensa la altura del header fijo (h-16) -->
		<div class="pt-16 flex-1">
			<slot />
		</div>
		<Footer />
		<WhatsAppFlotante />
	</body>
</html>
