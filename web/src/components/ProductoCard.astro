---
// Props que recibe este componente desde index.astro
const { id, nombre, precio, categoria, descripcion, stock, imagenUrl, whatsappUrl } = Astro.props;

const precioFormateado = precio?.toLocaleString('es-AR', {
  style: 'currency',
  currency: 'ARS',
  minimumFractionDigits: 0,
});

const categoriaLabel = categoria
  ? categoria.charAt(0).toUpperCase() + categoria.slice(1)
  : 'Otros';
---

<article data-product-card data-categoria={categoria ?? 'otros'} class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300 border border-amber-100 flex flex-col">

  <!-- Imagen del producto -->
  <div class="relative aspect-square overflow-hidden bg-amber-50">
    {imagenUrl ? (
      <img
        src={imagenUrl}
        alt={nombre}
        class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-amber-200">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      </div>
    )}

    <!-- Badge de stock agotado -->
    {stock === 0 && (
      <span class="absolute top-2 left-2 bg-gray-800 text-white text-xs font-semibold px-2 py-1 rounded-full">
        Sin stock
      </span>
    )}
  </div>

  <!-- Información del producto -->
  <div class="p-4 flex flex-col gap-2 flex-1">
    <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-500">
      {categoriaLabel}
    </p>

    <h2 class="text-sm font-semibold text-amber-900 leading-tight line-clamp-2">
      {nombre}
    </h2>

    {descripcion && (
      <p class="text-xs text-gray-500 line-clamp-2 leading-relaxed">
        {descripcion}
      </p>
    )}

    <p class="text-lg font-bold text-amber-700 mt-auto">
      {precioFormateado}
    </p>

    <!-- Botón Agregar al carrito -->
    <button
      data-add-to-cart
      data-producto-id={id}
      data-producto-nombre={nombre}
      data-producto-precio={precio}
      class="w-full mt-1 py-2 px-3 rounded-xl bg-amber-700 hover:bg-amber-800 active:scale-95 text-white text-sm font-semibold transition-all duration-150 disabled:opacity-40 disabled:cursor-not-allowed cursor-pointer"
      disabled={stock === 0}
    >
      🛒 Agregar al carrito
    </button>

    <!-- Botón WhatsApp -->
    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="w-full py-2 px-3 rounded-xl bg-green-500 hover:bg-green-600 text-white text-sm font-semibold text-center transition-colors duration-150"
    >
      💬 Consultar por WhatsApp
    </a>
  </div>

</article>

<script>
  import { addToCart } from '../store/cartStore.js';

  // Busca todos los botones de "Agregar" en la página (Astro deduplica este script,
  // pero querySelectorAll los encuentra a todos porque el DOM ya está listo)
  document.querySelectorAll('[data-add-to-cart]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id     = btn.dataset.productoId;
      const nombre = btn.dataset.productoNombre;
      const precio = Number(btn.dataset.productoPrecio);

      addToCart({ id, nombre, precio });

      // Feedback visual: el botón confirma por 1.5 segundos
      const original = btn.innerHTML;
      btn.innerHTML = '✓ ¡Agregado!';
      btn.disabled = true;
      setTimeout(() => {
        btn.innerHTML = original;
        btn.disabled = false;
      }, 1500);
    });
  });
</script>
