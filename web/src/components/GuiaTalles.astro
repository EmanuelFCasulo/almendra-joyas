---
// GuiaTalles.astro - Modal con Guía de Talles para Anillos
---

<div
  id="guia-talles-backdrop"
  class="fixed inset-0 bg-black/50 backdrop-blur-sm z-40 items-center justify-center p-4 hidden"
>
  <!-- Modal -->
  <div
    id="guia-talles-modal"
    class="bg-white rounded-2xl shadow-2xl max-w-md w-full animate-modal-in"
  >
    <!-- Header con botón cerrar -->
    <div class="flex items-center justify-between p-6 border-b border-amber-100">
      <h2 class="text-xl font-bold text-amber-900">Guía de Talles</h2>
      <button
        id="guia-talles-close"
        aria-label="Cerrar modal"
        class="text-gray-400 hover:text-gray-600 transition-colors p-1 hover:bg-gray-100 rounded-lg"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-6 h-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"
          />
        </svg>
      </button>
    </div>

    <!-- Contenido -->
    <div class="p-6 space-y-4">
      <p class="text-gray-700 leading-relaxed">
        <strong>¿Cómo medir tu anillo en casa?</strong>
      </p>

      <div class="bg-amber-50 rounded-lg p-4 space-y-3">
        <div class="flex gap-3">
          <span class="shrink-0 w-6 h-6 rounded-full bg-amber-700 text-white flex items-center justify-center text-sm font-bold">
            1
          </span>
          <p class="text-sm text-gray-700">
            Imprime una <strong>guía de talles</strong> o usa un anillo que te calce bien.
          </p>
        </div>

        <div class="flex gap-3">
          <span class="shrink-0 w-6 h-6 rounded-full bg-amber-700 text-white flex items-center justify-center text-sm font-bold">
            2
          </span>
          <p class="text-sm text-gray-700">
            <strong>Mide el diámetro interior</strong> del anillo con una regla en milímetros.
          </p>
        </div>

        <div class="flex gap-3">
          <span class="shrink-0 w-6 h-6 rounded-full bg-amber-700 text-white flex items-center justify-center text-sm font-bold">
            3
          </span>
          <p class="text-sm text-gray-700">
            <strong>Consulta nuestra tabla de talles</strong> en la descripción del producto.
          </p>
        </div>
      </div>

      <div class="pt-2">
        <p class="text-xs text-gray-500 italic">
          💡 Tip: Mide en un momento del día cuando tu dedo está a temperatura normal. Los dedos pueden cambiar de tamaño con el calor y el frío.
        </p>
      </div>
    </div>

    <!-- Footer -->
    <div class="p-6 border-t border-amber-100 flex gap-3">
      <button
        id="guia-talles-close-btn"
        class="flex-1 py-2 px-4 rounded-xl bg-gray-100 hover:bg-gray-200 text-gray-800 font-semibold transition-colors text-sm"
      >
        Entendido
      </button>
      <button
        id="guia-talles-whatsapp"
        class="flex-1 py-2 px-4 rounded-xl bg-green-500 hover:bg-green-600 text-white font-semibold transition-colors text-sm flex items-center justify-center gap-2"
      >
        <span>💬</span>
        <span>Consultar</span>
      </button>
    </div>
  </div>
</div>

<script>
  // Referencias a elementos
  const backdrop = document.getElementById('guia-talles-backdrop') as HTMLElement | null;
  const closeBtn = document.getElementById('guia-talles-close') as HTMLElement | null;
  const closeBtnFooter = document.getElementById('guia-talles-close-btn') as HTMLElement | null;
  const whatsappBtn = document.getElementById('guia-talles-whatsapp') as HTMLElement | null;

  // Función para abrir modal (será global)
  (window as any).openGuiaTalles = function() {
    if (backdrop) {
      backdrop.classList.remove('hidden');
      backdrop.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }
  };

  // Función para cerrar modal
  function closeModal() {
    if (backdrop) {
      backdrop.classList.add('hidden');
      backdrop.classList.remove('flex');
      document.body.style.overflow = 'auto';
    }
  }

  // Event listeners para cerrar
  if (closeBtn) closeBtn.addEventListener('click', closeModal);
  if (closeBtnFooter) closeBtnFooter.addEventListener('click', closeModal);

  // Cerrar al clickear fuera del modal
  if (backdrop) {
    backdrop.addEventListener('click', (e) => {
      if (e.target === backdrop) {
        closeModal();
      }
    });
  }

  // WhatsApp button
  if (whatsappBtn) {
    whatsappBtn.addEventListener('click', () => {
      const mensaje = encodeURIComponent(
        'Hola! Tengo una consulta sobre los talles de los anillos. 🌸'
      );
      window.open(`https://wa.me/541121584057?text=${mensaje}`, '_blank');
    });
  }

  // Cerrar con tecla ESC
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && backdrop && !backdrop.classList.contains('hidden')) {
      closeModal();
    }
  });
</script>

<style>
  @keyframes modalSlideIn {
    from {
      transform: scale(0.95) translateY(10px);
      opacity: 0;
    }
    to {
      transform: scale(1) translateY(0);
      opacity: 1;
    }
  }

  .animate-modal-in {
    animation: modalSlideIn 0.3s ease-out forwards;
  }
</style>
