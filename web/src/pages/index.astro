---
import Layout from '../layouts/Layout.astro';
import ProductoCard from '../components/ProductoCard.astro';
import { client, urlFor } from '../lib/sanityClient.js';

const productos = await client.fetch(`*[_type == "producto"] | order(_createdAt asc) {
  _id,
  nombre,
  precio,
  categoria,
  stock,
  descripcion,
  imagen
}`);
---

<Layout>
  <main class="max-w-6xl mx-auto px-4 py-10">

    <!-- Subtítulo de sección -->
    <div class="text-center mb-8">
      <p class="text-gray-400 italic">Bijouterie artesanal con amor ✨</p>
    </div>

    <div class="flex flex-wrap items-center justify-center gap-2 mb-8" data-filter-group>
      <button type="button" class="categoria-btn rounded-full border border-amber-200 bg-amber-700 px-4 py-2 text-sm font-semibold text-white transition-colors" data-filter="todos" aria-pressed="true">
        Todos
      </button>
      <button type="button" class="categoria-btn rounded-full border border-amber-200 bg-white px-4 py-2 text-sm font-semibold text-amber-800 transition-colors hover:bg-amber-50" data-filter="anillos" aria-pressed="false">
        Anillos
      </button>
      <button type="button" class="categoria-btn rounded-full border border-amber-200 bg-white px-4 py-2 text-sm font-semibold text-amber-800 transition-colors hover:bg-amber-50" data-filter="pulseras" aria-pressed="false">
        Pulseras
      </button>
      <button type="button" class="categoria-btn rounded-full border border-amber-200 bg-white px-4 py-2 text-sm font-semibold text-amber-800 transition-colors hover:bg-amber-50" data-filter="collares" aria-pressed="false">
        Collares
      </button>
      <button type="button" class="categoria-btn rounded-full border border-amber-200 bg-white px-4 py-2 text-sm font-semibold text-amber-800 transition-colors hover:bg-amber-50" data-filter="aros" aria-pressed="false">
        Aros
      </button>
    </div>

    <!-- Grilla de productos -->
    <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5" data-product-grid>
      {productos.map((producto: any) => (
        <ProductoCard
          id={producto._id}
          nombre={producto.nombre}
          precio={producto.precio}
          categoria={producto.categoria}
          descripcion={producto.descripcion}
          stock={producto.stock}
          imagenUrl={producto.imagen ? urlFor(producto.imagen).width(500).height(500).fit('crop').url() : null}
          whatsappUrl={`https://wa.me/541121584057?text=${encodeURIComponent(`Hola! Me interesa: ${producto.nombre} — $${producto.precio}. ¿Está disponible?`)}`}
        />
      ))}
    </div>

  </main>
</Layout>

<script>
  const filterButtons = document.querySelectorAll('[data-filter-group] [data-filter]');
  const productCards = document.querySelectorAll('[data-product-card]');

  function setActiveButton(activeButton: Element) {
    filterButtons.forEach((button) => {
      const isActive = button === activeButton;

      button.setAttribute('aria-pressed', String(isActive));
      button.classList.toggle('bg-amber-700', isActive);
      button.classList.toggle('text-white', isActive);
      button.classList.toggle('bg-white', !isActive);
      button.classList.toggle('text-amber-800', !isActive);
      button.classList.toggle('hover:bg-amber-50', !isActive);
    });
  }

  filterButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const btnElement = button as HTMLElement;
      const selectedCategory = btnElement.dataset.filter;

      setActiveButton(button);

      productCards.forEach((card) => {
        const cardElement = card as HTMLElement;
        const cardCategory = cardElement.dataset.categoria;
        const shouldShow = selectedCategory === 'todos' || cardCategory === selectedCategory;

        cardElement.classList.toggle('hidden', !shouldShow);
      });
    });
  });
</script>

