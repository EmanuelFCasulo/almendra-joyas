---
import Layout from '../layouts/Layout.astro';
import { client, urlFor } from '../lib/sanityClient.js';

// Consulta GROQ: trae todos los documentos de tipo "producto"
const productos = await client.fetch(`*[_type == "producto"]{
  _id,
  nombre,
  precio,
  stock,
  descripcion,
  imagen
}`);
---

<Layout>
  <main>
    <h1>✨ Almendra Joyas</h1>
    <p class="subtitulo">Catálogo de bijouterie artesanal</p>

    <div class="catalogo">
      {productos.map((producto) => (
        <div class="tarjeta">
          {producto.imagen && (
            <img
              src={urlFor(producto.imagen).width(400).height(400).fit('crop').url()}
              alt={producto.nombre}
              width="400"
              height="400"
            />
          )}
          <div class="info">
            <h2>{producto.nombre}</h2>
            {producto.descripcion && <p class="descripcion">{producto.descripcion}</p>}
            <p class="precio">${producto.precio?.toLocaleString('es-AR')}</p>
            <p class="stock">Stock disponible: {producto.stock}</p>
            <a
              class="btn-whatsapp"
              href={`https://wa.me/5491158575160?text=${encodeURIComponent(`Hola! Me interesa: ${producto.nombre} - $${producto.precio}`)}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              💬 Pedir por WhatsApp
            </a>
          </div>
        </div>
      ))}
    </div>
  </main>
</Layout>

<style>
  main {
    font-family: Georgia, serif;
    max-width: 960px;
    margin: 0 auto;
    padding: 2rem 1rem;
    color: #3a3a3a;
  }

  h1 {
    font-size: 2.2rem;
    text-align: center;
    margin-bottom: 0.25rem;
    color: #8b5e3c;
  }

  .subtitulo {
    text-align: center;
    color: #999;
    margin-bottom: 2rem;
    font-style: italic;
  }

  .catalogo {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .tarjeta {
    border: 1px solid #e8d5c4;
    border-radius: 12px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 2px 8px rgba(0,0,0,0.07);
    display: flex;
    flex-direction: column;
  }

  .tarjeta img {
    width: 100%;
    height: 260px;
    object-fit: cover;
  }

  .info {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .info h2 {
    font-size: 1.1rem;
    margin: 0;
    color: #5a3e2b;
  }

  .descripcion {
    font-size: 0.9rem;
    color: #777;
    margin: 0;
  }

  .precio {
    font-size: 1.3rem;
    font-weight: bold;
    color: #8b5e3c;
    margin: 0;
  }

  .stock {
    font-size: 0.8rem;
    color: #aaa;
    margin: 0;
  }

  .btn-whatsapp {
    display: block;
    margin-top: auto;
    padding: 0.6rem 1rem;
    background-color: #25d366;
    color: white;
    text-align: center;
    border-radius: 8px;
    text-decoration: none;
    font-weight: bold;
    font-size: 0.95rem;
  }

  .btn-whatsapp:hover {
    background-color: #1da851;
  }
</style>
